# Memora backend environment variables
# Copy to .env and modify

# Database
DATABASE_URL=sqlite:///./memora.db

# Optional: debug mode (prints SQL)
DEBUG=false

# LLM (DeepSeek / OpenAI compatible)
# LLM_API_KEY=sk-xxx
# LLM_API_BASE=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# Storage
UPLOAD_DIR=uploads
